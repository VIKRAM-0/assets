# Copy this file to `.env.local` and fill in your real values, then run `vercel dev`.
# For testing curtains you ONLY need the 4 AWS vars below.
# GEMINI_API_KEY is only needed for the AI fabric generator (not curtains).

AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET=your-bucket-name

# Optional — only for the AI "find/generate fabric" features:
# GEMINI_API_KEY=your-gemini-key
